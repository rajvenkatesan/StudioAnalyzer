# Google Places API key — required for studio discovery
GOOGLE_PLACES_API_KEY=your_key_here

# SQLite database file path
DATABASE_URL="file:./dev.db"

# API server port
PORT=3001

# Milliseconds to wait between Playwright page requests (reduces bot-detection risk)
SCRAPER_CRAWL_DELAY_MS=1500

# Set to true to replay recorded Places API fixtures instead of hitting Google (for offline tests)
DISCOVERY_FIXTURE=false
