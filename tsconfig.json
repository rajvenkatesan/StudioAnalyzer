{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/api/**/*", "src/shared/**/*", "tests/**/*"],
  "exclude": ["src/web/**/*", "node_modules", "dist"]
}
